{
  "name": "hkgd-worker",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute hkgd-db --local --file=./schema.sql",
    "db:migrate:remote": "wrangler d1 execute hkgd-db --remote --file=./schema.sql",
    "db:export": "node scripts/export-data.js",
    "db:seed": "wrangler d1 execute hkgd-db --remote --file=./seed.sql"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "hono": "^4.6.0",
    "jose": "^5.9.0",
    "react-sortable-hoc": "^2.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241230.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.78.0"
  }
}
